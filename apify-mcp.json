{
  "mcpServers": {
    "apify": {
      "command": "npx",
      "args": [
        "-y",
        "@apify/mcp-server"
      ],
      "env": {
        "APIFY_TOKEN": "YOUR_APIFY_TOKEN"
      },
      "url": "https://mcp.apify.com/?tools=actors,docs,experimental,runs,storage,compass/crawler-google-places"
    }
  }
}
