# Database
DATABASE_URL=postgresql://prospecting:prospecting@localhost:5432/prospecting

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# Apify (free tier)
APIFY_TOKEN=your_free_tier_token
APIFY_ACTOR_NAME=uprising-coldoutreach-crawler

# App Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Tracking base URL (for email open/click tracking)
TRACKING_BASE_URL=http://localhost:8000

# ── SMS — TextBelt (free open-source Twilio alternative) ───────────────────
# Self-hosted: point to your TextBelt instance
# Public: use https://textbelt.com/text (free tier: 1 SMS/day)
TEXTBELT_URL=https://textbelt.com/text
TEXTBELT_API_KEY=textbelt

# ── Gmail OAuth (Gmail API — higher deliverability than SMTP) ──────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/integrations/gmail/callback

# ── Instagram DM (Graph API via Facebook Business) ─────────────────────────
# Create app at https://developers.facebook.com/apps
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:8000/integrations/instagram/callback

# ── Webhooks ───────────────────────────────────────────────────────────────
# HMAC-SHA256 secret for validating inbound webhook signatures (optional)
WEBHOOK_SECRET=
